# =============================================================================
# Modèle de configuration Snowflake pour le dashboard Streamlit (mode LOCAL).
#
# 1. Copier ce fichier vers .streamlit/secrets.toml
# 2. Renseigner vos valeurs
# 3. NE JAMAIS commiter .streamlit/secrets.toml  → ajoutez-le au .gitignore :
#        .streamlit/secrets.toml
#
# En "Streamlit in Snowflake", ce fichier est inutile : la session active
# est utilisée automatiquement (aucun credential).
# =============================================================================

[snowflake]
account = "xxxxx-xxxxx"          # ex : ab12345.eu-west-1
user = "ABRAHAMKOLOBOE"
role = "SHOPFLOW_ENGINEER"
warehouse = "WH_TRANSFORM"
database = "SHOPFLOW_DB"
schema = "STAGING"

# --- Authentification : choisir UNE méthode ---
# a) Navigateur (SSO/MFA, recommandé — aucun mot de passe stocké) :
authenticator = "externalbrowser"

# b) Mot de passe (décommenter, et retirer la ligne authenticator ci-dessus) :
# password = "VOTRE_MOT_DE_PASSE"
